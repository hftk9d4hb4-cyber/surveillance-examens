{
  "name": "surveillance-examens",
  "version": "1.1.0-rc.2",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "vercel-build": "sh -c 'export DATABASE_URL=\"${DATABASE_URL:-$POSTGRES_PRISMA_URL}\"; export DATABASE_URL_UNPOOLED=\"${DATABASE_URL_UNPOOLED:-${POSTGRES_URL_NON_POOLING:-$POSTGRES_URL}}\"; prisma generate && prisma migrate deploy && next build'",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/**/*.test.ts",
    "db:validate": "prisma validate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "lint": "eslint .",
    "check": "npm run lint && npm run typecheck && npm test"
  },
  "dependencies": {
    "@prisma/client": "6.19.0",
    "bcryptjs": "2.4.3",
    "csv-parse": "5.6.0",
    "date-fns": "4.1.0",
    "date-fns-tz": "3.2.0",
    "exceljs": "4.4.0",
    "next": "15.5.20",
    "next-auth": "4.24.14",
    "nodemailer": "7.0.7",
    "react": "19.1.1",
    "react-dom": "19.1.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/node": "22.15.3",
    "@types/nodemailer": "7.0.0",
    "@types/react": "19.1.2",
    "@types/react-dom": "19.1.2",
    "eslint": "9.25.1",
    "eslint-config-next": "15.5.20",
    "prisma": "6.19.0",
    "tsx": "4.20.6",
    "typescript": "5.8.3"
  }
}
