generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum Role {
  TEACHER
  MANAGER
  ADMIN
}

enum HalfDay {
  AM
  PM
}

enum AvailabilityStatus {
  UNAVAILABLE
  WEAK_AVAILABLE
  AVAILABLE
  STRONG_AVAILABLE
}

enum AbsenceType {
  VACATION
  CONFERENCE
  TRAINING
  MISSION
  PERSONAL
  OTHER
}

enum ExamStatus {
  DRAFT
  PUBLISHED
  CANCELLED
}

enum CampaignStatus {
  PREPARATION
  COLLECTING
  ASSIGNING
  PUBLISHED
  CLOSED
}

enum AssignmentSource {
  AUTO
  MANUAL
}

enum ConvocationStatus {
  PENDING
  SENT
  ERROR
}



enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum AlertType {
  MISSING_AVAILABILITY
  UNDERSTAFFED_EXAM
  DOUBLE_ASSIGNMENT
  UNAVAILABLE_TEACHER
  QUOTA_EXCEEDED
  EXTRA_TIME_UNDERSTAFFED
  DATA_QUALITY
}

enum ImportKind {
  TEACHERS
  EXAMS
}

enum ImportStatus {
  SUCCESS
  PARTIAL
  ERROR
}

model User {
  id               String            @id @default(cuid())
  firstName        String?
  lastName         String?
  name             String
  email            String            @unique
  passwordHash     String?
  role             Role              @default(TEACHER)
  department       String?
  speciality       String?
  quotaAnnual      Int?
  isActive         Boolean           @default(true)
  mustChangePassword Boolean         @default(true)
  activationSentAt DateTime?
  lastLoginAt      DateTime?
  availabilities   Availability[]
  absencePeriods   TeacherAbsence[]
  preferences      TeacherPreference[]
  assignments      Assignment[]
  convocations     Convocation[]
  activationTokens ActivationToken[]
  acknowledgements AssignmentAcknowledgement[]
  campaignsManaged Campaign[] @relation("CampaignManager")
  alertsResolved   CampaignAlert[] @relation("CampaignAlertResolver")
  importLogs       ImportLog[]        @relation("ImportCreator")
  auditLogs        AuditLog[]         @relation("AuditActor")
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([role, isActive])
  @@index([lastName, firstName])
}

model ActivationToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId, expiresAt])
}

model Campaign {
  id                  String         @id @default(cuid())
  name                String
  academicYear        String
  promotion           String
  startDate           DateTime       @db.Date
  endDate             DateTime       @db.Date
  responseDeadline    DateTime?      @db.Date
  collectionStartedAt DateTime?
  status              CampaignStatus @default(PREPARATION)
  managerId           String?
  manager             User?          @relation("CampaignManager", fields: [managerId], references: [id], onDelete: SetNull)
  exams               Exam[]
  alerts              CampaignAlert[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@unique([academicYear, promotion, name], name: "campaignNaturalKey")
  @@index([academicYear, status])
  @@index([managerId, status])
  @@index([startDate, endDate])
}

model Exam {
  id                  String        @id @default(cuid())
  externalId          String?       @unique
  title               String
  date                DateTime      @db.Date
  halfDay             HalfDay
  startTime           String
  endTime             String
  timezone            String        @default("Europe/Paris")
  academicYear        String
  promotion           String
  location            String
  requiredSupervisors Int
  status              ExamStatus    @default(PUBLISHED)
  notes               String?
  campaignId          String?
  campaign            Campaign?     @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  assignments         Assignment[]
  convocations        Convocation[]
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@unique([date, halfDay, title, location], name: "examNaturalKey")
  @@index([academicYear, date, halfDay])
  @@index([status, date])
  @@index([campaignId, date])
}

model Availability {
  id        String             @id @default(cuid())
  userId    String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime           @db.Date
  halfDay   HalfDay
  status    AvailabilityStatus
  comment   String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@unique([userId, date, halfDay])
  @@index([date, halfDay, status])
}

model Assignment {
  id           String           @id @default(cuid())
  examId       String
  exam         Exam             @relation(fields: [examId], references: [id], onDelete: Cascade)
  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  score        Float
  scoreDetails Json?
  source       AssignmentSource @default(AUTO)
  locked       Boolean          @default(false)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  convocation  Convocation?
  acknowledgement AssignmentAcknowledgement?

  @@unique([examId, userId])
  @@index([userId, createdAt])
}

model AssignmentAcknowledgement {
  id             String     @id @default(cuid())
  assignmentId   String     @unique
  assignment     Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  userId         String
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  acknowledgedAt DateTime   @default(now())
  createdAt      DateTime   @default(now())

  @@index([userId, acknowledgedAt])
}

model Convocation {
  id           String             @id @default(cuid())
  assignmentId String             @unique
  assignment   Assignment         @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  examId       String
  exam         Exam               @relation(fields: [examId], references: [id], onDelete: Cascade)
  userId       String
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  status       ConvocationStatus  @default(PENDING)
  sentAt       DateTime?
  lastError    String?
  messageId    String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([examId, status])
  @@index([userId, status])
}

model ImportLog {
  id          String       @id @default(cuid())
  kind        ImportKind
  status      ImportStatus
  fileName    String
  totalRows   Int
  createdRows Int          @default(0)
  updatedRows Int          @default(0)
  skippedRows Int          @default(0)
  errorRows   Int          @default(0)
  errors      Json?
  createdById String?
  createdBy   User?        @relation("ImportCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime     @default(now())

  @@index([kind, createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actor     User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String?
  details   Json?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([createdAt])
}


model TeacherAbsence {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      AbsenceType
  startDate DateTime    @db.Date
  endDate   DateTime    @db.Date
  comment   String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([userId, startDate, endDate])
  @@index([startDate, endDate])
}

model TeacherPreference {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekday   Int
  halfDay   HalfDay
  weight    Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, weekday, halfDay])
  @@index([weekday, halfDay, weight])
}


model AssignmentEngineConfig {
  id                    String   @id @default(cuid())
  academicYear          String   @unique
  availabilityWeight    Int      @default(35)
  quotaWeight           Int      @default(25)
  fairnessWeight        Int      @default(20)
  recencyWeight         Int      @default(10)
  preferenceWeight      Int      @default(10)
  extraTimeMultiplier   Float    @default(1.5)
  maxAssignmentsPerDay  Int      @default(1)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([academicYear])
}

model AssignmentSimulation {
  id             String   @id @default(cuid())
  academicYear   String
  createdById    String?
  status         String   @default("PREVIEW")
  parameters     Json
  result         Json
  anomalyCount   Int      @default(0)
  assignmentCount Int     @default(0)
  validatedAt    DateTime?
  createdAt      DateTime @default(now())

  @@index([academicYear, createdAt])
  @@index([createdById, createdAt])
}


model CampaignAlert {
  id            String        @id @default(cuid())
  campaignId    String
  campaign      Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  type          AlertType
  severity      AlertSeverity
  fingerprint   String
  title         String
  message       String
  entityType    String?
  entityId      String?
  resolutionUrl String?
  resolvedAt    DateTime?
  resolvedById  String?
  resolvedBy    User?         @relation("CampaignAlertResolver", fields: [resolvedById], references: [id], onDelete: SetNull)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([campaignId, fingerprint])
  @@index([campaignId, resolvedAt, severity])
  @@index([type, createdAt])
}
